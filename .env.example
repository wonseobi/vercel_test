# .env.example
# Copy to `.env` for `vercel dev`. These are the DEFAULT local Supabase CLI
# values — `supabase start` prints the exact anon key, paste it here if it
# differs. Never commit a real .env.

# Consumed by the Vercel function (api/flags.ts)
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlzcyI6InN1cGFiYXNlLWRlbW8iLCJpYXQiOjE2NDE3NjkyMDAsImV4cCI6MTc5OTUzNTYwMH0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE

# --- Optional overrides consumed by app.config.js -------------------------
# Point staging / production builds at different backends. If unset, both fall
# back to the local stack above.
STAGING_API_URL=http://localhost:3000
STAGING_SUPABASE_URL=http://localhost:54321
PROD_API_URL=http://localhost:3000
PROD_SUPABASE_URL=http://localhost:54321
