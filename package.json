{
  "name": "config-flags-app",
  "version": "1.0.0",
  "private": true,
  "description": "Lightweight RN app that securely displays environment-specific feature flags based on account status.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "APP_ENV=staging expo start",
    "start:staging": "APP_ENV=staging expo start",
    "start:device": "IP=$(ipconfig getifaddr en0 || ipconfig getifaddr en1); APP_ENV=staging STAGING_API_URL=http://$IP:3000 STAGING_SUPABASE_URL=http://$IP:54321 expo start",
    "start:production": "APP_ENV=production expo start",
    "android:staging": "APP_ENV=staging expo run:android",
    "android:production": "APP_ENV=production expo run:android",
    "ios:staging": "APP_ENV=staging expo run:ios",
    "ios:production": "APP_ENV=production expo run:ios",
    "db:start": "supabase start",
    "db:reset": "supabase db reset",
    "db:stop": "supabase stop",
    "api:dev": "npx vercel dev --listen 3000",
    "api:local": "node scripts/local-api.mjs",
    "test:e2e": "maestro test .maestro/login_flow.yaml"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "expo": "^54.0.0",
    "expo-constants": "~18.0.13",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  }
}
